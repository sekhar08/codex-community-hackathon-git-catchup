{
  "name": "git-catchup",
  "version": "0.1.0",
  "description": "AI-assisted CLI for safely catching up on incoming mainline changes after time away from your branch.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "git",
    "cli",
    "merge",
    "rebase",
    "post-holiday",
    "catchup"
  ],
  "bin": {
    "git-catchup": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsc --watch -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "dotenv": "^16.4.7",
    "ink": "^6.8.0",
    "openai": "^4.0.0",
    "ora": "^8.2.0",
    "react": "^19.2.0",
    "simple-git": "^3.28.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.50",
    "@types/react": "^19.2.2",
    "typescript": "^5.8.3"
  }
}
